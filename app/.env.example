# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # API Bearer token for tRPC mutations (required in production)

# ── Script-only mode（默认开启，禁止写生产库）────────────────────
# ALLOW_EXECUTE=true   # 开发环境解除 SCRIPT_ONLY，允许真实 execute
# SCRIPT_ONLY 由 !ALLOW_EXECUTE 推导，无需单独设置

# Frontend (dev): set same value so mutations pass auth when APP_SECRET is set
VITE_APP_SECRET=

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── File uploads ───────────────────────────────────────────────
UPLOAD_DIR=               # Local upload directory (default: ./uploads)

# ── LLM (OpenAI-compatible) ────────────────────────────────────
LLM_BASE_URL=             # e.g. https://api.cts.flamelephant.com
LLM_API_KEY=              # API key (never commit real keys)
LLM_MODEL=MiniMax-M2.7    # Model name
